 // Flatten a tree into a vector of arrays
 std::vector<mx::array> tree_flatten(VALUE tree, bool strict) {
@@ -199,18 +255,43 @@ VALUE rb_tree_unflatten(VALUE self, VALUE tree, VALUE values) {
